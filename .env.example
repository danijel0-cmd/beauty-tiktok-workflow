# Google Drive API Credentials
GOOGLE_DRIVE_CREDENTIALS=config/google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here

# TikTok Video Settings
TIKTOK_WIDTH=1080
TIKTOK_HEIGHT=1920
TIKTOK_FPS=30
TIKTOK_BITRATE=8M

# Hook Detection Settings
HOOK_MIN_LENGTH=1
HOOK_MAX_LENGTH=3
MIN_MOTION_THRESHOLD=0.4
SCENE_CHANGE_THRESHOLD=25.0

# Metadata Generation
AUTO_HASHTAGS=true
DEFAULT_HASHTAGS=beauty,makeup,skincare,beautycare,tiktok,viral
INCLUDE_EMOJIS=true

# Processing
MAX_VIDEO_LENGTH=300
PARALLEL_PROCESSING=false
CLEANUP_TEMP_FILES=true

# Output
OUTPUT_FORMAT=mp4
EXPORT_TO_CAPCUT=true
CAPCUT_PROJECT_NAME=auto_beauty_video
